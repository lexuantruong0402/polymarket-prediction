# ── Predict Market Bot Configuration ──

# API (Polymarket)
API_BASE_URL=https://gamma-api.polymarket.com
CLOB_API_URL=https://clob.polymarket.com
API_KEY=your-api-key-here

# External Research & Intelligence
NEWS_API_KEY=your_newsapi_key_here
OPENAI_API_KEY=your_openai_key_here
GEMINI_API_KEY=your_gemini_key_here

# Models
MODEL_PATH=data/models/xgboost_market_v1.json

# Portfolio
BANKROLL=10000.0
MAX_EXPOSURE=0.30
KELLY_ALPHA=0.25

# Risk Limits
EDGE_THRESHOLD=0.04
MDD_LIMIT=0.08
VAR_LIMIT_DAILY=500.0
CONFIDENCE_THRESHOLD=0.60

# Scanner
MIN_LIQUIDITY=5000.0
MIN_VOLUME=1000.0
SCAN_LIMIT=300

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
